# Oracle Forge — Environment Variables Template
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── LLM API access ────────────────────────────────────────────────────────────
# OpenRouter (used by data_agent.py as the default LLM provider)
ANTHROPIC_API_KEY=sk-or-v1-YOUR_OPENROUTER_KEY_HERE

# Model selection — default provider is OpenAI
# OPENAI_MODEL: gpt-4.1 (recommended), gpt-4.1-mini (cheaper), gpt-4o-mini (baseline)
OPENROUTER_MODEL=openai/gpt-4.1
ORACLE_FORGE_LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4.1

# Strong benchmark tuning (optional; script also sets safe defaults)
ORACLE_FORGE_MAX_ITERATIONS=28
ORACLE_FORGE_TOOL_PREVIEW_ROWS=120

# ── MCP server ────────────────────────────────────────────────────────────────
# URL the agent uses to reach the MCP toolbox server
MCP_URL=http://127.0.0.1:5000/mcp

# Port the MCP server listens on (mcp/toolbox_server.py)
MCP_PORT=5000

# ── DataAgentBench ─────────────────────────────────────────────────────────────
# Absolute path to the DataAgentBench checkout (defaults to ./DataAgentBench)
DATAAGENTBENCH_ROOT=/shared/oracle-forge/DataAgentBench

# Optional context controls (useful for debugging prompt size/ablation):
# ORACLE_FORGE_STRICT_OMIT_KB=1            # omit core KB + corrections + domain KB in strict mode
# ORACLE_FORGE_MAX_SYSTEM_PROMPT_CHARS=60000
# ORACLE_FORGE_MAX_SCHEMA_SECTION_CHARS=12000
# ORACLE_FORGE_MAX_DB_DESCRIPTION_CHARS=12000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_USER=oracle_forge
PG_PASSWORD=your_postgres_password_here

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/

# ── Injection tester (utils/injection_tester.py) ─────────────────────────────
# Only needed when running KB injection tests — not required for agent operation
OPENAI_API_KEY=sk-YOUR_OPENAI_KEY_HERE
GOOGLE_API_KEY=your_google_api_key_here
